---
// Footer.astro
---

<footer class="w-full bg-[#EDEFEA] pt-20 pb-8 px-6 md:px-12 text-[#111827]">
  <div class="max-w-[1600px] mx-auto">
    
    <div class="flex flex-col lg:flex-row justify-between gap-16 mb-20">
      
      <!-- Left Section -->
      <div class="w-full lg:w-[45%] flex flex-col">
        <!-- Logo & Text -->
        <div class="flex items-center gap-6 mb-8">
          <!-- Logo Text -->
          <div class="flex items-center gap-3">
            <svg class="w-8 h-8 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            <span class="text-3xl lg:text-4xl font-sans tracking-tighter text-gray-800">UnEspacio</span>
          </div>
          <!-- Divider -->
          <div class="w-px h-10 bg-gray-300 hidden md:block"></div>
          <!-- Text -->
          <p class="text-gray-500 text-sm font-sans max-w-[200px] leading-relaxed hidden md:block">
            Mantente actualizado con nuestras últimas guías de hogar y jardinería.
          </p>
        </div>

        <!-- Newsletter Input -->
        <div class="relative w-full max-w-md">
          <input 
            type="email" 
            placeholder="Tu correo electrónico ..." 
            class="w-full bg-[#E8EFE5] text-gray-800 placeholder-gray-500 py-4 pl-6 pr-16 focus:outline-none focus:ring-2 focus:ring-gray-400 transition-shadow font-sans text-[15px]"
          />
          <button class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full flex items-center justify-center hover:bg-black hover:text-white transition-colors duration-300 shadow-sm">
            <svg class="w-4 h-4 transform -rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </button>
        </div>
      </div>

      <!-- Right Section (Links Grid) -->
      <div class="w-full lg:w-[50%] grid grid-cols-2 md:grid-cols-3 gap-10 lg:gap-8 font-sans">
        
        <!-- Column 1 -->
        <div class="flex flex-col gap-6">
          <h4 class="text-sm font-bold uppercase tracking-widest text-gray-800">SOPORTE</h4>
          <div class="flex flex-col gap-4">
            <a href="/faq" class="text-[13px] text-gray-600 hover:text-black uppercase tracking-wider transition-colors">FAQ</a>
            <a href="/guia" class="text-[13px] text-gray-600 hover:text-black uppercase tracking-wider transition-colors">Guía de Usuario</a>
            <a href="/testimonios" class="text-[13px] text-gray-600 hover:text-black uppercase tracking-wider transition-colors">Testimonios</a>
            <a href="/contacto" class="text-[13px] text-gray-600 hover:text-black uppercase tracking-wider transition-colors">Contacto</a>
          </div>
        </div>

        <!-- Column 2 -->
        <div class="flex flex-col gap-6">
          <h4 class="text-sm font-bold uppercase tracking-widest text-gray-800">ENLACES</h4>
          <div class="flex flex-col gap-4">
            <a href="/sobre-nosotros" class="text-[13px] text-gray-600 hover:text-black uppercase tracking-wider transition-colors">Sobre Nosotros</a>
            <a href="/galeria" class="text-[13px] text-gray-600 hover:text-black uppercase tracking-wider transition-colors">Galería</a>
            <a href="/proyectos" class="text-[13px] text-gray-600 hover:text-black uppercase tracking-wider transition-colors">Proyectos</a>
            <a href="/blog" class="text-[13px] text-gray-600 hover:text-black uppercase tracking-wider transition-colors">Blog</a>
          </div>
        </div>

        <!-- Column 3 -->
        <div class="flex flex-col gap-6">
          <h4 class="text-sm font-bold uppercase tracking-widest text-gray-800">CATEGORÍAS</h4>
          <div class="flex flex-col gap-4">
            <a href="/jardineria" class="text-[13px] text-gray-600 hover:text-black uppercase tracking-wider transition-colors">Jardinería</a>
            <a href="/plantas" class="text-[13px] text-gray-600 hover:text-black uppercase tracking-wider transition-colors">Selección de Plantas</a>
            <a href="/paisajismo" class="text-[13px] text-gray-600 hover:text-black uppercase tracking-wider transition-colors">Paisajismo</a>
            <a href="/reformas" class="text-[13px] text-gray-600 hover:text-black uppercase tracking-wider transition-colors">Reformas</a>
          </div>
        </div>

      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="w-full border-t border-gray-300 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-[11px] text-gray-500 uppercase tracking-widest font-sans">
        COPYRIGHT © {new Date().getFullYear()} UNESPACIO. TODOS LOS DERECHOS RESERVADOS.
      </p>
      <div class="flex items-center gap-3 text-[11px] text-gray-500 uppercase tracking-widest font-sans">
        <a href="/privacidad" class="hover:text-black transition-colors">POLÍTICA DE PRIVACIDAD</a>
        <span>|</span>
        <a href="/terminos" class="hover:text-black transition-colors">TÉRMINOS Y CONDICIONES</a>
      </div>
    </div>

  </div>
</footer>
