---
---

<section class="relative h-screen w-full flex items-end pb-12 px-6 md:px-12 pt-32 overflow-hidden">
  <!-- Fondo de imagen -->
  <div class="absolute inset-0 z-0">
    <!-- Imagen de Unsplash de arquitectura y jardín premium -->
    <img 
      src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=2070&auto=format&fit=crop" 
      alt="Diseño de exteriores y hogar moderno con jardín" 
      class="w-full h-full object-cover scale-105 origin-center animate-[subtle-zoom_20s_ease-out_forwards]"
    />
    <!-- Overlays para legibilidad y estética -->
    <div class="absolute inset-0 bg-black/30"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-black/10"></div>
  </div>

  <!-- Contenido Principal -->
  <div class="relative z-10 w-full flex flex-col md:flex-row justify-between items-end gap-8 md:gap-4 mb-4 md:mb-0">
    <h1 class="font-display font-bold text-6xl md:text-8xl lg:text-[100px] leading-[0.85] text-white tracking-tighter uppercase">
      Inspiración Para<br />
      Tu Hogar y Jardín
    </h1>
    
    <div class="text-white flex items-center gap-3 font-sans text-[10px] md:text-[11px] font-bold tracking-widest uppercase pb-2 md:pb-[1.5vw]">
      <span>HAZ SCROLL</span>
      <span class="animate-bounce text-lg">↓</span>
    </div>
  </div>
</section>

<style>
  @keyframes subtle-zoom {
    0% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }
</style>
