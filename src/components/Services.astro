---

<section class="w-full bg-[#FAFAFA] text-[#0F172A] py-20 px-6 md:px-12 relative overflow-hidden">
  <div class="max-w-[1600px] mx-auto">
    
    <!-- Top Header -->
    <div class="flex flex-col lg:flex-row justify-between items-end mb-6 gap-8">
      <!-- Left side: Title -->
      <div class="w-full lg:w-2/3">
        <div class="flex items-center gap-2 mb-4 text-[#4B5563]">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <span class="text-[10px] font-bold tracking-widest uppercase font-sans">Explora Nuestras Guías</span>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl text-[#111827] tracking-tight font-sans">
          <span class="font-normal">INSPIRACIÓN. IDEAS. HOGAR.</span><br/>
          <span class="font-normal">LAS MEJORES GUÍAS PARA TU ESPACIO.</span>
        </h2>
      </div>

      <!-- Right side: Paragraph -->
      <div class="w-full lg:w-1/3 lg:pl-12">
        <p class="text-[13px] md:text-[14px] text-gray-700 leading-relaxed font-sans max-w-[400px]">
          Descubre nuestros artículos y guías paso a paso con las mejores ideas de decoración, jardinería y reformas para transformar tu hogar.
        </p>
      </div>
    </div>

    <!-- Solid Black Divider Line -->
    <div class="w-full h-[1px] bg-black mb-6"></div>

    <!-- Explore Button -->
    <div class="flex justify-end mb-12">
      <a href="/servicios" class="inline-flex items-center gap-3 px-5 py-2 border border-black rounded-full text-[10px] font-bold tracking-widest uppercase hover:bg-gray-50 transition-colors duration-300">
        EXPLORAR SERVICIOS 
        <div class="w-5 h-5 rounded-full bg-black text-white flex items-center justify-center">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 19L19 5M19 5v10M19 5H9"/></svg>
        </div>
      </a>
    </div>

    <!-- Grid de Servicios (3 columnas x 3 filas = 9 items) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 bg-white border-t border-l border-black/10">
      
      {services.map((service) => (
        <a href="/servicios" class="service-card group relative w-full h-[140px] lg:h-[150px] px-8 py-6 flex flex-col justify-start gap-4 overflow-hidden bg-white border-b border-r border-black/10 cursor-none">
          
          <!-- Fondo expansivo (Círculo que crece desde el icono) -->
          <div class="absolute top-6 left-8 w-12 h-12 bg-[#0F172A] rounded-full scale-0 group-hover:scale-[45] transition-transform duration-[600ms] ease-[cubic-bezier(0.4,0,0.2,1)] z-0 origin-center pointer-events-none"></div>

          <!-- Top: Icono con círculo centrado -->
          <div class="relative z-10 w-full pointer-events-none">
            <div class="relative inline-flex items-center justify-center w-12 h-12 rounded-full bg-gray-100 group-hover:bg-transparent transition-colors duration-[400ms] text-[#0F172A] group-hover:text-white">
              <span class="relative z-10 block" set:html={service.icon}></span>
            </div>
          </div>
          
          <!-- Bottom: Título (Izquierda) -->
          <div class="relative z-10 w-full pointer-events-none mt-1">
            <h3 class="text-[13px] lg:text-[14px] font-sans font-medium uppercase tracking-wide text-[#0F172A] group-hover:text-white transition-colors duration-300">
              {service.title}
            </h3>
          </div>
        </a>
      ))}
      
    </div>
  </div>

  <!-- Elemento de Custom Cursor Global -->
  <div id="service-cursor" class="hidden md:flex fixed top-0 left-0 pointer-events-none z-50 opacity-0 items-center gap-2 bg-[#FDFBF7] text-black pl-4 pr-2 py-1.5 rounded-full shadow-2xl transition-opacity duration-300 ease-out will-change-transform" style="transform: translate3d(-50%, -50%, 0) scale(0.5);">
    <span class="text-[10px] font-bold tracking-[0.1em] uppercase whitespace-nowrap">Ver Artículos</span>
    <div class="bg-[#0F172A] text-white rounded-full w-5 h-5 flex items-center justify-center">
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </div>
  </div>
</section>

<script>
  // Inicialización del custom cursor
  const initCustomCursor = () => {
    const cards = document.querySelectorAll('.service-card');
    const cursor = document.getElementById('service-cursor');
    
    // Solo ejecutamos si estamos en escritorio (donde aplica el hover)
    if (cursor && window.innerWidth >= 768) {
      let mouseX = 0;
      let mouseY = 0;
      let isHovering = false;
      let animationFrameId;
      
      const updateCursor = () => {
        if (isHovering) {
          // El cursor se centra en el ratón y se escala a 1 cuando está activo
          cursor.style.transform = `translate3d(calc(${mouseX}px - 50%), calc(${mouseY}px - 50%), 0) scale(1)`;
        } else {
          // Cuando no está activo, reducimos la escala a 0.5 para el efecto fade-out
          cursor.style.transform = `translate3d(calc(${mouseX}px - 50%), calc(${mouseY}px - 50%), 0) scale(0.5)`;
        }
        animationFrameId = requestAnimationFrame(updateCursor);
      };
      
      cards.forEach(card => {
        card.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          // Si el cursor no estaba visible, lo forzamos (para la primera entrada rápida)
          if (!isHovering) {
            isHovering = true;
            cursor.style.opacity = '1';
            if (!animationFrameId) updateCursor();
          }
        });
        
        card.addEventListener('mouseenter', () => {
          isHovering = true;
          cursor.style.opacity = '1';
          if (!animationFrameId) updateCursor();
        });
        
        card.addEventListener('mouseleave', () => {
          isHovering = false;
          cursor.style.opacity = '0';
          // Dejamos que el RAF siga corriendo brevemente para la animación de salida
          setTimeout(() => {
            if (!isHovering && animationFrameId) {
              cancelAnimationFrame(animationFrameId);
              animationFrameId = null;
            }
          }, 300);
        });
      });
    }
  };

  // Astro View Transitions lifecycle
  document.addEventListener('astro:page-load', initCustomCursor);
  // Ejecución directa para la primera carga sin view transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCustomCursor);
  } else {
    initCustomCursor();
  }
</script>
