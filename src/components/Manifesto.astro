---
// Manifesto.astro
---

<section class="relative w-full bg-[#111111] text-white py-32 md:py-48 px-6 md:px-12 overflow-hidden flex items-center justify-center min-h-[80vh]">
  
  <!-- Subtle Blueprint / Grid Background Pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255, 255, 255, 1) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 1) 1px, transparent 1px); background-size: 40px 40px;"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-[#111111] via-transparent to-[#111111] pointer-events-none"></div>

  <!-- Floating Image 1 (Left) -->
  <div class="absolute left-[-5%] md:left-[5%] top-[10%] md:top-[15%] w-[250px] md:w-[350px] lg:w-[450px] aspect-[4/3] rotate-[-8deg] opacity-60 md:opacity-80 mix-blend-luminosity hover:mix-blend-normal hover:opacity-100 hover:rotate-0 hover:z-20 transition-all duration-700 ease-out shadow-2xl grayscale hover:grayscale-0 pointer-events-auto">
    <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&q=80&w=800" alt="Diseño de exteriores moderno" class="w-full h-full object-cover border-[8px] border-[#1a1a1a]" />
  </div>

  <!-- Floating Image 2 (Right) -->
  <div class="absolute right-[-10%] md:right-[5%] bottom-[5%] md:bottom-[10%] w-[280px] md:w-[380px] lg:w-[480px] aspect-video rotate-[6deg] opacity-60 md:opacity-80 mix-blend-luminosity hover:mix-blend-normal hover:opacity-100 hover:rotate-0 hover:z-20 transition-all duration-700 ease-out shadow-2xl grayscale hover:grayscale-0 pointer-events-auto">
    <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80&w=800" alt="Arquitectura sostenible" class="w-full h-full object-cover border-[8px] border-[#1a1a1a]" />
  </div>

  <!-- Main Text -->
  <div class="relative z-30 max-w-5xl mx-auto text-center pointer-events-none">
    <h2 class="text-3xl md:text-5xl lg:text-7xl xl:text-[80px] font-medium leading-[1.05] tracking-tight text-transparent bg-clip-text bg-gradient-to-br from-white via-white to-gray-500 uppercase drop-shadow-2xl">
      "Construimos más que espacios físicos — Diseñamos hogares eficientes y exteriores sostenibles pensados para transformar tu calidad de vida."
    </h2>
  </div>
  
</section>
