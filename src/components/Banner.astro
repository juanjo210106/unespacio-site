---
// Banner.astro
---

<section class="relative w-full h-[450px] md:h-[550px] overflow-hidden my-16">
  
  <!-- Background Image -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80&w=1920" alt="Patio moderno exterior" class="w-full h-full object-cover" />
    
    <!-- Gradient Overlay (Darker on the left for text readability) -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent"></div>
  </div>

  <!-- Content Container -->
  <div class="relative z-10 w-full h-full max-w-[1600px] mx-auto px-6 md:px-16 flex flex-col justify-center items-start">
    
    <!-- Title -->
    <h2 class="text-4xl md:text-5xl lg:text-[64px] font-sans font-medium text-white max-w-3xl leading-[1.1] mb-10 tracking-tight drop-shadow-md">
      ¿LISTO PARA TRANSFORMAR <br class="hidden md:block"/>
      TU HOGAR?
    </h2>
    
    <!-- CTA Button -->
    <a href="/articulos" class="bg-[#FDFBF7] text-[#0F172A] px-10 py-4 font-sans text-[15px] font-bold hover:bg-white hover:scale-105 transition-all duration-300 shadow-xl border border-transparent hover:border-gray-200">
      Ver Todas Las Guías
    </a>
    
  </div>
  
</section>
