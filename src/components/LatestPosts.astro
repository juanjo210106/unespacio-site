---
// LatestPosts.astro
const posts = [
  {
    title: "CÓMO DISEÑAR UN JARDÍN DE BAJO MANTENIMIENTO",
    category: "JARDINERÍA",
    image: "https://images.unsplash.com/photo-1584738766473-61c083514bf4?auto=format&fit=crop&q=80&w=800",
    url: "/blog/jardin-bajo-mantenimiento"
  },
  {
    title: "TENDENCIAS EN DECORACIÓN DE EXTERIORES PARA 2024",
    category: "DECORACIÓN",
    image: "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80&w=800",
    url: "/blog/tendencias-exteriores-2024"
  },
  {
    title: "GUÍA COMPLETA SOBRE PANELES SOLARES EN CASA",
    category: "SOSTENIBILIDAD",
    image: "https://images.unsplash.com/photo-1508514177221-188b1cf16e9d?auto=format&fit=crop&q=80&w=800",
    url: "/blog/guia-paneles-solares"
  }
];
---

<section class="w-full bg-[#FDFBF7] py-24 md:py-32 px-6 md:px-12">
  <div class="max-w-[1600px] mx-auto">
    
    <!-- Top Header Area -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-8">
      <h2 class="text-4xl md:text-5xl lg:text-[56px] font-sans text-[#111827] uppercase tracking-tight leading-[1.05] max-w-4xl">
        IDEAS, TENDENCIAS, <br class="hidden lg:block"/>
        PENSAMIENTOS Y CONSEJOS
      </h2>
      <p class="text-gray-600 text-[14px] md:text-[15px] max-w-[320px] leading-relaxed md:text-right">
        Mantente al día con las últimas tendencias de arquitectura, diseño exterior y nuestras guías paso a paso.
      </p>
    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-black/10 mb-8"></div>

    <!-- Button Area -->
    <div class="flex justify-end mb-12">
      <a href="/blog" class="group inline-flex items-center gap-3 px-5 py-2 rounded-full border border-gray-300 text-[#111827] font-sans text-[11px] font-bold uppercase tracking-wider hover:border-black transition-colors duration-300">
        VER TODOS LOS ARTÍCULOS
        <div class="w-[22px] h-[22px] bg-[#111827] text-white rounded-full flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
          <svg class="w-3 h-3 transform -rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </div>
      </a>
    </div>

    <!-- Grid Area -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-10">
      {posts.map((post) => (
        <a href={post.url} class="group block cursor-pointer">
          <!-- Image -->
          <div class="w-full aspect-[4/3] overflow-hidden mb-6 bg-gray-100">
            <img src={post.image} alt={post.title} class="w-full h-full object-cover transition-transform duration-[800ms] ease-out group-hover:scale-105" />
          </div>
          
          <!-- Category Pill -->
          <div class="inline-block px-3 py-1.5 mb-4 rounded-full border border-gray-200 text-gray-500 text-[9px] font-bold uppercase tracking-widest font-sans bg-white shadow-sm">
            {post.category}
          </div>
          
          <!-- Title -->
          <h3 class="text-xl lg:text-[22px] font-sans text-[#111827] uppercase leading-[1.2] font-medium group-hover:text-gray-500 transition-colors duration-300">
            {post.title}
          </h3>
        </a>
      ))}
    </div>
    
  </div>
</section>
