---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const articles = [
  { title: "Licencias de Obra Menor y Mayor", image: "https://images.unsplash.com/photo-1503387762-592deb58ef4e?q=80&w=600&auto=format&fit=crop" },
  { title: "Cómo Calcular un Presupuesto Real", image: "https://images.unsplash.com/photo-1541888081696-6e27bd326442?q=80&w=600&auto=format&fit=crop" },
  { title: "Materiales de Construcción Sostenibles", image: "https://images.unsplash.com/photo-1518709268805-4e9042af9f23?q=80&w=600&auto=format&fit=crop" },
  { title: "Aislamiento Térmico Eficiente", image: "https://images.unsplash.com/photo-1600607686527-6fb886090705?q=80&w=600&auto=format&fit=crop" }
];
---

<BaseLayout title="Reformas | UnEspacio">
  <Header />
  
  <div class="relative w-full h-[50vh] min-h-[400px]">
    <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?q=80&w=2000&auto=format&fit=crop" alt="Reformas" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6">
      <div class="inline-block px-4 py-1.5 mb-6 rounded-full border border-white/30 bg-white/10 backdrop-blur-md text-[11px] font-bold uppercase tracking-widest font-sans text-white">
        Categoría
      </div>
      <h1 class="text-5xl md:text-6xl font-sans font-bold text-white tracking-tight drop-shadow-lg mb-4">Reformas</h1>
      <p class="text-lg md:text-xl text-white/90 font-sans max-w-2xl leading-relaxed">
        Todo lo que necesitas saber antes de derribar el primer tabique. Consejos estructurales, legales y estéticos.
      </p>
    </div>
  </div>

  <div class="py-24 bg-white">
    <div class="max-w-[1200px] mx-auto px-6">
      <h2 class="text-3xl font-sans font-bold text-[#111827] mb-12 border-b border-gray-200 pb-4">Guías Destacadas</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {articles.map((a) => (
          <a href="#" class="group block">
            <div class="aspect-square rounded-2xl overflow-hidden bg-gray-200 mb-4">
              <img src={a.image} alt={a.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            </div>
            <h3 class="font-sans font-bold text-[#111827] text-lg leading-snug group-hover:text-blue-600 transition-colors">{a.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
