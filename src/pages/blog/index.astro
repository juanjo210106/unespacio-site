---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';

// Manual list of existing blog posts
const posts = [
  {
    url: "/blog/tendencias-exteriores-2024",
    title: "Tendencias en Decoración de Exteriores para 2024",
    category: "Decoración",
    image: "https://images.unsplash.com/photo-1600607688969-a5bfcd64bd28?q=80&w=1200&auto=format&fit=crop",
    date: "10 Abril, 2024"
  },
  {
    url: "/blog/jardin-bajo-mantenimiento",
    title: "Cómo Diseñar un Jardín de Bajo Mantenimiento Paso a Paso",
    category: "Jardinería",
    image: "https://images.unsplash.com/photo-1558904541-efa843a96f0a?q=80&w=1200&auto=format&fit=crop",
    date: "15 Abril, 2024"
  },
  {
    url: "/blog/guia-paneles-solares",
    title: "Guía Completa Sobre Paneles Solares en Casa",
    category: "Sostenibilidad",
    image: "https://images.unsplash.com/photo-1509391366360-128f000302b1?q=80&w=1200&auto=format&fit=crop",
    date: "20 Abril, 2024"
  }
];
---

<BaseLayout title="Blog Editorial | UnEspacio">
  <Header />
  
  <div class="pt-32 pb-24 bg-white min-h-screen">
    <div class="max-w-[1200px] mx-auto px-6">
      
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
        <div>
          <h1 class="text-4xl md:text-5xl font-sans font-bold text-[#111827] mb-4 tracking-tight">Revista Editorial</h1>
          <p class="text-lg text-gray-600 font-sans max-w-xl">
            Nuestros últimos artículos, guías y consejos redactados por expertos en arquitectura y paisajismo.
          </p>
        </div>
        <div class="flex gap-2">
          <span class="bg-[#0F172A] text-white px-4 py-2 rounded-full text-[11px] font-bold uppercase tracking-widest font-sans cursor-pointer">Todos</span>
          <span class="bg-gray-100 text-gray-600 px-4 py-2 rounded-full text-[11px] font-bold uppercase tracking-widest font-sans cursor-pointer hover:bg-gray-200">Jardinería</span>
          <span class="bg-gray-100 text-gray-600 px-4 py-2 rounded-full text-[11px] font-bold uppercase tracking-widest font-sans cursor-pointer hover:bg-gray-200">Reformas</span>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a href={post.url} class="group block flex flex-col h-full border border-gray-100 rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300">
            <div class="relative aspect-[4/3] bg-gray-200 overflow-hidden">
              <img src={post.image} alt={post.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
              <div class="absolute top-4 left-4 bg-white/90 backdrop-blur text-[#0F172A] px-3 py-1 rounded-full text-[11px] font-bold uppercase tracking-widest font-sans">
                {post.category}
              </div>
            </div>
            <div class="p-6 bg-white flex-1 flex flex-col justify-between">
              <div>
                <p class="text-xs text-gray-500 font-sans font-medium mb-3">{post.date}</p>
                <h2 class="text-xl font-sans font-bold text-[#111827] mb-4 leading-snug group-hover:text-blue-600 transition-colors">
                  {post.title}
                </h2>
              </div>
              <span class="text-sm font-sans font-bold text-[#0F172A] flex items-center gap-2 group-hover:gap-3 transition-all">
                Leer Artículo <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>
</BaseLayout>
