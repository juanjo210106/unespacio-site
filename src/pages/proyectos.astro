---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const projects = [
  {
    title: "Reforma Integral en Madrid",
    category: "Reformas",
    image: "https://images.unsplash.com/photo-1600607686527-6fb886090705?q=80&w=1200&auto=format&fit=crop",
    desc: "Transformación completa de un piso de los años 70 en un espacio diáfano y moderno con alta eficiencia energética."
  },
  {
    title: "Jardín Seco Mediterráneo",
    category: "Paisajismo",
    image: "https://images.unsplash.com/photo-1558904541-efa843a96f0a?q=80&w=1200&auto=format&fit=crop",
    desc: "Diseño de un jardín de muy bajo consumo hídrico utilizando especies autóctonas y pavimentos permeables."
  },
  {
    title: "Autoconsumo en Vivienda Unifamiliar",
    category: "Sostenibilidad",
    image: "https://images.unsplash.com/photo-1509391366360-128f000302b1?q=80&w=1200&auto=format&fit=crop",
    desc: "Instalación de 12 paneles solares con inversor híbrido que cubren el 80% de la demanda eléctrica del hogar."
  },
  {
    title: "Terraza Urbana Chill-out",
    category: "Exteriores",
    image: "https://images.unsplash.com/photo-1600607688969-a5bfcd64bd28?q=80&w=1200&auto=format&fit=crop",
    desc: "Aprovechamiento de 25m2 en un ático con tarima sintética, pérgola bioclimática e iluminación LED perimetral."
  }
];
---

<BaseLayout title="Casos de Estudio y Proyectos | UnEspacio">
  <Header />
  
  <div class="pt-32 pb-24 bg-[#FDFBF7] min-h-screen">
    <div class="max-w-[1400px] mx-auto px-6">
      
      <div class="mb-16">
        <h1 class="text-4xl md:text-5xl font-sans font-bold text-[#111827] mb-4 tracking-tight">Casos de Estudio</h1>
        <p class="text-lg text-gray-600 font-sans max-w-2xl">
          Análisis en profundidad de proyectos reales: presupuestos, tiempos de ejecución y soluciones a problemas comunes en obra y paisajismo.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        {projects.map((p) => (
          <a href="#" class="group block">
            <div class="relative rounded-2xl overflow-hidden aspect-[4/3] mb-6 bg-gray-200">
              <img src={p.image} alt={p.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
              <div class="absolute top-4 left-4 bg-white/90 backdrop-blur text-[#0F172A] px-3 py-1 rounded-full text-[11px] font-bold uppercase tracking-widest font-sans">
                {p.category}
              </div>
            </div>
            <h2 class="text-2xl font-sans font-bold text-[#111827] mb-2 group-hover:text-blue-600 transition-colors">{p.title}</h2>
            <p class="text-gray-600 font-sans leading-relaxed">{p.desc}</p>
          </a>
        ))}
      </div>

    </div>
  </div>
</BaseLayout>
