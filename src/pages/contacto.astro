---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Contacto | UnEspacio">
  <Header />
  
  <div class="pt-32 pb-24 bg-[#FDFBF7] min-h-screen">
    <div class="max-w-[1200px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
      
      <!-- Info Column -->
      <div>
        <h1 class="text-4xl md:text-5xl font-sans font-bold text-[#111827] mb-6 tracking-tight">Hablemos</h1>
        <p class="text-lg text-gray-600 font-sans mb-12">
          ¿Tienes alguna duda sobre un artículo, quieres proponernos una colaboración o simplemente saludar? Estamos al otro lado de la pantalla.
        </p>

        <div class="space-y-8 font-sans">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center shadow-sm shrink-0 text-[#0F172A]">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <h4 class="font-bold text-[#111827] mb-1">Email</h4>
              <p class="text-gray-600">hola@unespacio.es</p>
            </div>
          </div>
          
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center shadow-sm shrink-0 text-[#0F172A]">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <div>
              <h4 class="font-bold text-[#111827] mb-1">Estudio Editorial</h4>
              <p class="text-gray-600">Madrid, España<br/>(Solo con cita previa)</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Form Column -->
      <div class="bg-white p-8 md:p-12 rounded-3xl shadow-xl border border-gray-100">
        <form class="flex flex-col gap-6 font-sans">
          
          <div class="flex flex-col gap-2">
            <label for="name" class="text-sm font-bold text-gray-700">Nombre completo</label>
            <input type="text" id="name" placeholder="Ej. Ana García" class="w-full bg-[#FDFBF7] border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#0F172A]/20 focus:border-[#0F172A] transition-all" />
          </div>

          <div class="flex flex-col gap-2">
            <label for="email" class="text-sm font-bold text-gray-700">Correo electrónico</label>
            <input type="email" id="email" placeholder="ana@ejemplo.com" class="w-full bg-[#FDFBF7] border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#0F172A]/20 focus:border-[#0F172A] transition-all" />
          </div>

          <div class="flex flex-col gap-2">
            <label for="subject" class="text-sm font-bold text-gray-700">Asunto</label>
            <select id="subject" class="w-full bg-[#FDFBF7] border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#0F172A]/20 focus:border-[#0F172A] transition-all appearance-none">
              <option>Duda sobre un artículo</option>
              <option>Propuesta de colaboración</option>
              <option>Problemas técnicos</option>
              <option>Otro</option>
            </select>
          </div>

          <div class="flex flex-col gap-2">
            <label for="message" class="text-sm font-bold text-gray-700">Mensaje</label>
            <textarea id="message" rows="5" placeholder="¿En qué podemos ayudarte?" class="w-full bg-[#FDFBF7] border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#0F172A]/20 focus:border-[#0F172A] transition-all resize-none"></textarea>
          </div>

          <button type="button" class="w-full bg-[#0F172A] text-white rounded-xl py-4 font-bold uppercase tracking-wider text-sm hover:bg-black transition-colors mt-4">
            Enviar Mensaje
          </button>
          
        </form>
      </div>

    </div>
  </div>
</BaseLayout>
