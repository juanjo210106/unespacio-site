---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const articles = [
  { title: "Herramientas Básicas para Empezar", image: "https://images.unsplash.com/photo-1416879598555-46e3cb588a4e?q=80&w=600&auto=format&fit=crop" },
  { title: "Riego por Goteo: Guía Definitiva", image: "https://images.unsplash.com/photo-1585320806297-9794b3e4ce88?q=80&w=600&auto=format&fit=crop" },
  { title: "Calendario de Siembra 2024", image: "https://images.unsplash.com/photo-1592424001806-6415777a28e9?q=80&w=600&auto=format&fit=crop" },
  { title: "Control de Plagas Ecológico", image: "https://images.unsplash.com/photo-1530836369250-ef71a3fb90e6?q=80&w=600&auto=format&fit=crop" }
];
---

<BaseLayout title="Jardinería | UnEspacio">
  <Header />
  
  <div class="relative w-full h-[50vh] min-h-[400px]">
    <img src="https://images.unsplash.com/photo-1558904541-efa843a96f0a?q=80&w=2000&auto=format&fit=crop" alt="Jardinería" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6">
      <div class="inline-block px-4 py-1.5 mb-6 rounded-full border border-white/30 bg-white/10 backdrop-blur-md text-[11px] font-bold uppercase tracking-widest font-sans text-white">
        Categoría
      </div>
      <h1 class="text-5xl md:text-6xl font-sans font-bold text-white tracking-tight drop-shadow-lg mb-4">Jardinería</h1>
      <p class="text-lg md:text-xl text-white/90 font-sans max-w-2xl leading-relaxed">
        Técnicas, herramientas y consejos prácticos para mantener tus espacios exteriores vivos y saludables en cualquier estación.
      </p>
    </div>
  </div>

  <div class="py-24 bg-white">
    <div class="max-w-[1200px] mx-auto px-6">
      <h2 class="text-3xl font-sans font-bold text-[#111827] mb-12 border-b border-gray-200 pb-4">Guías Destacadas</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {articles.map((a) => (
          <a href="#" class="group block">
            <div class="aspect-square rounded-2xl overflow-hidden bg-gray-200 mb-4">
              <img src={a.image} alt={a.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            </div>
            <h3 class="font-sans font-bold text-[#111827] text-lg leading-snug group-hover:text-green-700 transition-colors">{a.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
